<?xml version="1.0" encoding="utf-8"?>
<!-- Segmented toggle fill: palette accent when selected, transparent (outlined) otherwise. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:color="?attr/paletteAccent" android:state_checked="true" />
    <item android:color="@android:color/transparent" />
</selector>
