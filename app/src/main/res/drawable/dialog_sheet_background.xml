<?xml version="1.0" encoding="utf-8"?>
<!-- Provider bottom sheet: the app's warm glass sweep, rounded at the top. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:angle="135"
        android:startColor="@color/glass_bg_top"
        android:centerColor="@color/glass_bg_mid"
        android:endColor="@color/glass_bg_bottom" />
    <stroke android:width="1dp" android:color="@color/glass_card_brd" />
    <corners android:topLeftRadius="28dp" android:topRightRadius="28dp" />
</shape>
