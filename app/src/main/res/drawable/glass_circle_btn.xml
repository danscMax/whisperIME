<?xml version="1.0" encoding="utf-8"?>
<!-- Theme-aware circular glass button: frosted fill + hairline, ripple on press. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/living_glass_pressed">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/glass_card" />
            <stroke android:width="1dp" android:color="@color/glass_card_brd" />
        </shape>
    </item>
</ripple>
