<?xml version="1.0" encoding="utf-8"?>
<!-- The living-signal cloud orb, the app's hero, on the warm glass. A sky-blue body lit from the
     top, a soft milk core, a bright rim and a cool contact shadow so it sits on the light glass.
     Kept inside the 66dp safe zone of the 108dp canvas (circle r=29 at 54,53 -> 24..82). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- soft contact shadow under the orb, for separation from the light background -->
    <path android:pathData="M54,57 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="54" android:centerY="60" android:gradientRadius="32"
                android:startColor="#5A5A79A8" android:centerColor="#2A5A79A8" android:endColor="#005A79A8" />
        </aapt:attr>
    </path>

    <!-- orb body: sky blue at the top fading to pale at the foot, the cloud gradient -->
    <path android:pathData="M54,53 m-29,0 a29,29 0 1,0 58,0 a29,29 0 1,0 -58,0 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="54" android:startY="24" android:endX="54" android:endY="82"
                android:startColor="#3E9BF3"
                android:centerColor="#83C4F8"
                android:endColor="#EAF5FE" />
        </aapt:attr>
    </path>

    <!-- milk highlight, offset toward the light (upper area) -->
    <path android:pathData="M50,44 m-18,0 a18,18 0 1,0 36,0 a18,18 0 1,0 -36,0 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="49" android:centerY="43" android:gradientRadius="20"
                android:startColor="#EEFFFFFF" android:centerColor="#66FFFFFF" android:endColor="#00FFFFFF" />
        </aapt:attr>
    </path>

    <!-- bright rim on the lit upper edge -->
    <path android:pathData="M54,53 m-29,0 a29,29 0 1,0 58,0 a29,29 0 1,0 -58,0 z"
        android:fillColor="#00000000" android:strokeWidth="1.4" android:strokeAlpha="0.6" android:strokeColor="#F2FAFF" />
</vector>
