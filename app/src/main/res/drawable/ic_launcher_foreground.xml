<?xml version="1.0" encoding="utf-8"?>
<!-- Aurora adaptive icon foreground: the living light bloom (same identity as the in-app orb) — a
     soft teal body lit from the upper-left, a white-hot offset core, a bright rim highlight and a
     cool deep edge for volume. Kept inside the 66dp safe zone of the 108dp canvas. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- outer glow halo, fades to transparent -->
    <path android:pathData="M54,54 m-40,0 a40,40 0 1,0 80,0 a40,40 0 1,0 -80,0 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="54" android:centerY="52" android:gradientRadius="40"
                android:startColor="#6653DBC9" android:centerColor="#2253DBC9" android:endColor="#0053DBC9" />
        </aapt:attr>
    </path>

    <!-- cool shadow lobe (lower-right) for volume -->
    <path android:pathData="M60,60 m-28,0 a28,28 0 1,0 56,0 a28,28 0 1,0 -56,0 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="60" android:centerY="60" android:gradientRadius="30"
                android:startColor="#99123152" android:centerColor="#44123152" android:endColor="#00123152" />
        </aapt:attr>
    </path>

    <!-- bloom body: bright teal, feathered edge -->
    <path android:pathData="M54,53 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="46" android:centerY="44" android:gradientRadius="36"
                android:startColor="#FF53DBC9" android:centerColor="#FF119E8C" android:endColor="#00006A60" />
        </aapt:attr>
    </path>

    <!-- white-hot core, offset toward the light (upper-left) -->
    <path android:pathData="M46,44 m-16,0 a16,16 0 1,0 32,0 a16,16 0 1,0 -32,0 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="46" android:centerY="44" android:gradientRadius="17"
                android:startColor="#FFFFFFFF" android:centerColor="#DDD8FFF6" android:endColor="#00FFFFFF" />
        </aapt:attr>
    </path>

    <!-- bright rim highlight on the lit edge -->
    <path android:pathData="M50,49 m-31,0 a31,31 0 1,0 62,0 a31,31 0 1,0 -62,0 z"
        android:fillColor="#00000000" android:strokeWidth="1.6" android:strokeAlpha="0.55" android:strokeColor="#BFF6EC" />
</vector>
