<?xml version="1.0" encoding="utf-8"?>
<!-- Monochrome layer for themed icons: the bloom reduced to a solid orb + one halo ring
     (the system applies its own tint). Kept inside the 66dp safe zone. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- solid orb -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,54 m-20,0 a20,20 0 1,0 40,0 a20,20 0 1,0 -40,0 z" />
    <!-- halo ring -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:fillColor="#00000000"
        android:pathData="M54,54 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0 z" />
</vector>
