<?xml version="1.0" encoding="utf-8"?>
<!-- IME voice dock backdrop. Translucent "glass" (not an opaque slab): the host app shows through so
     it reads as a floating panel over any app, light or dark. The dark-theme tone is a lifted navy,
     NOT near-black, so it never looks like a black rectangle over a light host. Rounded top only —
     it sits flush to the bottom edge. (Blur behind is added at runtime on API 31+.) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@color/ime_dock_glass" />
    <stroke android:width="1dp" android:color="@color/glass_card_brd" />
    <corners android:topLeftRadius="24dp" android:topRightRadius="24dp" />
</shape>
