<?xml version="1.0" encoding="utf-8"?>
<!-- Calm, near-uniform glass field (matches the flat IME-dock tone). A whisper of top-to-bottom depth,
     NO strong cool→warm sweep and no warm bloom, so every accent-coloured orb reads cleanly on it.
     Colours live in values/colors_glass.xml so the same field works after dark. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient android:angle="270"
        android:startColor="@color/glass_field_top"
        android:endColor="@color/glass_field_bottom" />
</shape>
