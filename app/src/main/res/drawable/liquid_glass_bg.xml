<?xml version="1.0" encoding="utf-8"?>
<!-- Warm liquid-glass backdrop: cool sky top-left fading to warm peach bottom-right. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="145" android:startColor="#D7EAF1" android:centerColor="#ECE6E4" android:endColor="#F8D6BB" />
        </shape>
    </item>
    <item android:gravity="top|left" android:width="560dp" android:height="560dp">
        <shape android:shape="oval">
            <gradient android:type="radial" android:centerX="0.28" android:centerY="0.22" android:gradientRadius="300dp"
                android:startColor="#7FC7E0F0" android:endColor="#00C7E0F0" />
        </shape>
    </item>
    <item android:gravity="bottom|right" android:width="620dp" android:height="620dp">
        <shape android:shape="oval">
            <gradient android:type="radial" android:centerX="0.72" android:centerY="0.78" android:gradientRadius="320dp"
                android:startColor="#66FBBE8E" android:endColor="#00FBBE8E" />
        </shape>
    </item>
</layer-list>
