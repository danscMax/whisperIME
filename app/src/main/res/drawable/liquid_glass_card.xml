<?xml version="1.0" encoding="utf-8"?>
<!-- Liquid-glass panel: frosted base + iridescent pastel sheen + diagonal light beam + rim. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_panel" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="35"
                android:startColor="@color/glass_iris_a"
                android:centerColor="@color/glass_iris_b"
                android:endColor="@color/glass_iris_c" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="300"
                android:startColor="@android:color/transparent"
                android:centerColor="@color/glass_beam"
                android:endColor="@android:color/transparent"
                android:centerX="0.35" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/glass_panel_brd" />
            <corners android:radius="26dp" />
        </shape>
    </item>
</layer-list>
