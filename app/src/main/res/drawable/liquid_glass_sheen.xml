<?xml version="1.0" encoding="utf-8"?>
<!-- Iridescent pastel sheen + a diagonal light beam, drawn inside the glass card (clipped by it). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="35"
                android:startColor="#2E6FA8FF"
                android:centerColor="#2270E0B0"
                android:endColor="#30FF9AD0" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="300"
                android:startColor="#00FFFFFF"
                android:centerColor="#42FFFFFF"
                android:endColor="#00FFFFFF"
                android:centerX="0.32" />
        </shape>
    </item>
</layer-list>
