<?xml version="1.0" encoding="utf-8"?>
<!-- Glass panel: top sheen fading into the translucent base + hairline border. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient
        android:angle="90"
        android:startColor="@color/aurora_panel"
        android:endColor="@color/living_panel_top" />
    <stroke android:width="1dp" android:color="@color/aurora_panel_brd" />
    <corners android:radius="24dp" />
    <padding android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp" />
</shape>
