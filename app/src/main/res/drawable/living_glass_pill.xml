<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/living_glass_pressed" />
            <stroke android:width="1dp" android:color="@color/living_glass_focus" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/aurora_panel" />
            <stroke android:width="1dp" android:color="@color/aurora_panel_brd" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</selector>
