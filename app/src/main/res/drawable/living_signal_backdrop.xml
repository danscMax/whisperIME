<?xml version="1.0" encoding="utf-8"?>
<!-- Ambient-depth backdrop: base gradient + soft coloured light blobs behind content. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/aurora_bg"
                android:centerColor="@color/living_bg_mid"
                android:endColor="@color/aurora_bg2" />
        </shape>
    </item>

    <!-- violet bloom, upper-left -->
    <item android:gravity="top|left" android:width="460dp" android:height="460dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerX="0.32"
                android:centerY="0.28"
                android:gradientRadius="230dp"
                android:startColor="@color/living_blob_a"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

    <!-- cyan bloom, upper-right -->
    <item android:gravity="top|right" android:width="360dp" android:height="360dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerX="0.66"
                android:centerY="0.3"
                android:gradientRadius="180dp"
                android:startColor="@color/living_blob_b"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

    <!-- magenta bloom, lower area -->
    <item android:gravity="bottom|center" android:width="620dp" android:height="440dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerX="0.5"
                android:centerY="0.7"
                android:gradientRadius="300dp"
                android:startColor="@color/living_blob_c"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
