<?xml version="1.0" encoding="utf-8"?>
<!-- Dropdown/menu popup. Opaque on purpose: a menu floats over the content it covers, so a
     translucent panel here let the widgets underneath read straight through the rows. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@color/menu_sheet" />
    <stroke android:width="1dp" android:color="@color/menu_sheet_brd" />
    <corners android:radius="18dp" />
</shape>
