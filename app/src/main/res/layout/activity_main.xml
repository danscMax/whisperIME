<?xml version="1.0" encoding="utf-8"?>
<!-- Aurora: dark-first, ChatGPT-voice idiom. The transcript is the content hero (centre); the
     living light orb is the record button, docked at the bottom within thumb reach. The accent
     (orb/wave/pills) follows the palette's colorPrimary. All view ids are preserved for MainActivity. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/aurora_bg_radial">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="20dp">

        <!-- top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/space_grotesk"
                android:text="@string/app_name"
                android:textColor="@color/aurora_ink"
                android:textFontWeight="700"
                android:textSize="22sp"
                android:letterSpacing="-0.02" />

            <ImageButton
                android:id="@+id/btnInfo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/aurora_circle_btn"
                android:src="@drawable/ic_info_48dp"
                app:tint="@color/aurora_ink"
                android:contentDescription="@string/info" />

            <ImageButton
                android:id="@+id/btnHistory"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/aurora_circle_btn"
                android:src="@drawable/ic_history_24dp"
                app:tint="@color/aurora_ink"
                android:contentDescription="@string/history_title" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/aurora_circle_btn"
                android:src="@drawable/ic_settings_24dp"
                app:tint="@color/aurora_ink"
                android:contentDescription="@string/settings_title" />

            <ImageButton
                android:id="@+id/btnOverflow"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/aurora_circle_btn"
                android:src="@drawable/ic_more_vert_24dp"
                app:tint="@color/aurora_ink"
                android:contentDescription="@string/main_cd_menu" />
        </LinearLayout>

        <!-- model + language pills -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/aurora_pill_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp">

            <Spinner
                android:theme="@style/ThemeOverlay.Aurora.OnDark"
                android:id="@+id/spnrTfliteFiles"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:popupBackground="@color/aurora_bg2" />

            <TextView
                android:id="@+id/badge_engine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/badge_background"
                android:fontFamily="@font/space_mono_regular"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="@string/main_badge_tflite"
                android:textColor="@color/aurora_ink"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/aurora_pill_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingVertical="2dp">

            <Spinner
                android:theme="@style/ThemeOverlay.Aurora.OnDark"
                android:id="@+id/spnrLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:popupBackground="@color/aurora_bg2" />
        </LinearLayout>

        <!-- CONTENT HERO: transcript panel fills the centre -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="14dp"
            android:background="@drawable/aurora_panel_bg"
            android:padding="18dp">

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/processing_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:indeterminate="true"
                android:visibility="invisible"
                app:trackCornerRadius="3dp" />

            <LinearLayout
                android:id="@+id/layout_result"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="top"
                    android:textColorHint="@color/aurora_ink_dim"
                    android:inputType="textMultiLine"
                    android:textColor="@color/aurora_ink"
                    android:textSize="18sp"
                    android:lineSpacingMultiplier="1.15"
                    android:textCursorDrawable="@null" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/perf_chip"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/space_mono_regular"
                        android:textColor="@color/aurora_ink_dim"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:id="@+id/layout_actions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageButton
                            android:id="@+id/fabCopy"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/aurora_circle_btn"
                            android:src="@drawable/ic_copy"
                            app:tint="@color/aurora_ink"
                            android:contentDescription="@string/copy_to_clipboard" />

                        <ImageButton
                            android:id="@+id/btnSpeak"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/aurora_circle_btn"
                            android:src="@drawable/ic_volume_up_24dp"
                            app:tint="@color/aurora_ink"
                            android:contentDescription="@string/main_cd_speak" />

                        <ImageButton
                            android:id="@+id/btnShare"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/aurora_circle_btn"
                            android:src="@drawable/ic_share_24dp"
                            app:tint="@color/aurora_ink"
                            android:contentDescription="@string/main_cd_share" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvReadyHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/space_mono_regular"
                android:text="@string/main_hint_ready"
                android:textColor="@color/aurora_ink_dim"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/layout_error"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_grotesk"
                    android:text="@string/main_error_title"
                    android:textColor="@color/aurora_ink"
                    android:textFontWeight="600"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="@string/main_error_hint"
                    android:textColor="@color/aurora_ink_dim"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRetry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/main_retry" />
            </LinearLayout>
        </FrameLayout>

        <!-- toggles -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/mode_append"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="14dp"
                android:buttonTint="@color/aurora_ink_dim"
                android:text="@string/append"
                android:textColor="@color/aurora_ink_dim"
                android:textSize="13sp" />

            <CheckBox
                android:id="@+id/mode_translate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/aurora_ink_dim"
                android:text="@string/translate"
                android:textColor="@color/aurora_ink_dim"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- recording readout (waveform + timer) shows above the orb only while recording -->
        <LinearLayout
            android:id="@+id/layout_recording"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <com.whispertflite.ui.WaveformView
                android:id="@+id/waveform"
                android:layout_width="match_parent"
                android:layout_height="40dp" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/space_mono_regular"
                android:text="0:00"
                android:textColor="@color/aurora_ink"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- BOTTOM: the orb record button within thumb reach -->
        <FrameLayout
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp">

            <com.whispertflite.ui.AuroraOrbView
                android:id="@+id/orb"
                android:layout_width="150dp"
                android:layout_height="150dp" />

            <ImageButton
                android:id="@+id/btnRecord"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/main_cd_record" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvHintTap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/space_mono_regular"
            android:text="@string/main_hint_tap"
            android:textColor="@color/aurora_ink_dim"
            android:textSize="12sp" />
    </LinearLayout>
</FrameLayout>
