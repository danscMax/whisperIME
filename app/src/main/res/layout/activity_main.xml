<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/liquid_glass_bg">

    <!-- Cap + centre the whole column so it doesn't stretch across a tablet; a ~640dp measure also
         keeps transcript lines readable instead of running edge-to-edge on a wide screen. -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="10dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:layout_constraintWidth_max="@dimen/content_max_width"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_grotesk"
                    android:letterSpacing="-0.03"
                    android:text="@string/app_name"
                    android:textColor="@color/glass_ink"
                    android:textFontWeight="700"
                    android:textSize="23sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_mono_regular"
                    android:letterSpacing="0.08"
                    android:text="@string/main_local_badge"
                    android:textAllCaps="true"
                    android:textColor="@color/glass_ink_dim"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Nav grouped into one frosted pill so the three icons read as a single control, and
                 kept in the header so the bottom belongs entirely to the orb. -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/glass_pill_bar"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp">

                <ImageButton
                    android:id="@+id/btnHistory"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/history_title"
                    android:padding="12dp"
                    android:src="@drawable/ic_history_24dp"
                    app:tint="@color/glass_ink" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@color/glass_card_brd" />

                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/settings_title"
                    android:padding="12dp"
                    android:src="@drawable/ic_settings_24dp"
                    app:tint="@color/glass_ink" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@color/glass_card_brd" />

                <ImageButton
                    android:id="@+id/btnOverflow"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/main_cd_menu"
                    android:padding="12dp"
                    android:src="@drawable/ic_more_vert_24dp"
                    app:tint="@color/glass_ink" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnInfo"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone"
                android:contentDescription="@string/info" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContext"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/glass_card"
            android:fontFamily="@font/space_grotesk"
            android:gravity="center_vertical"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingHorizontal="18dp"
            android:textColor="@color/glass_ink"
            android:textSize="15sp"
            app:cornerRadius="26dp"
            app:icon="@drawable/ic_expand_more_24dp"
            app:iconGravity="textEnd"
            app:iconTint="@color/glass_ink_dim"
            app:strokeColor="@color/glass_card_brd"
            app:strokeWidth="1dp" />

        <LinearLayout
            android:id="@+id/contextPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/living_glass_panel"
            android:elevation="10dp"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilModel"
                    style="@style/Widget.LivingSignal.Dropdown"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/select_model">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/spnrTfliteFiles"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/space_grotesk"
                        android:inputType="none"
                        android:popupBackground="@drawable/menu_sheet"
                        android:textColor="@color/glass_ink"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/badge_engine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/living_glass_pill"
                    android:fontFamily="@font/space_mono_regular"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:text="@string/main_badge_tflite"
                    android:textColor="@color/glass_ink"
                    android:textSize="11sp" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_language"
                style="@style/Widget.LivingSignal.Dropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/language">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/spnrLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_grotesk"
                    android:inputType="none"
                    android:popupBackground="@drawable/menu_sheet"
                    android:textColor="@color/glass_ink"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:chipSpacingHorizontal="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/mode_append"
                    style="@style/Widget.LivingSignal.Chip.Toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/append_short" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/mode_translate"
                    style="@style/Widget.LivingSignal.Chip.Toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/translate_short" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/transcriptPanel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:background="@drawable/living_glass_panel"
            android:minHeight="150dp"
            android:padding="18dp">

            <LinearLayout
                android:id="@+id/layout_result"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/space_grotesk"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:lineSpacingMultiplier="1.16"
                    android:textColor="@color/glass_ink"
                    android:textCursorDrawable="@null"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/perf_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_mono_regular"
                    android:textColor="@color/glass_ink_dim"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- labelFor makes this visible placeholder the accessibility label for the result field.
                 Best practice for editable text is labelFor on a visible label (not contentDescription,
                 which interferes with text navigation): TalkBack announces the hint, then the edit box. -->
            <TextView
                android:id="@+id/tvReadyHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:labelFor="@id/tvResult"
                android:fontFamily="@font/space_grotesk"
                android:gravity="center"
                android:text="@string/main_hint_ready"
                android:textColor="@color/glass_ink_dim"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/layout_error"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_grotesk"
                    android:text="@string/main_error_title"
                    android:textColor="@color/glass_ink"
                    android:textFontWeight="600"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:gravity="center"
                    android:text="@string/main_error_hint"
                    android:textColor="@color/glass_ink_dim"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRetry"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/main_retry" />
            </LinearLayout>
        </FrameLayout>

        <!-- Recording timer, its own line above the status so both can show while recording. -->
        <LinearLayout
            android:id="@+id/layout_recording"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/living_live_dot" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:fontFamily="@font/space_mono_regular"
                android:text="0:00"
                android:textColor="@color/glass_ink"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Status text and result actions share one fixed-height slot so swapping them never
             nudges the orb below. -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/dockStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/space_grotesk"
                android:gravity="center"
                android:text="@string/main_hold_signal"
                android:textColor="@color/glass_ink_dim"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/layout_actions"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageButton
                    android:id="@+id/fabCopy"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/copy_to_clipboard"
                    android:src="@drawable/ic_copy"
                    app:tint="@color/glass_ink" />

                <ImageButton
                    android:id="@+id/btnSpeak"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/main_cd_speak"
                    android:src="@drawable/ic_volume_up_24dp"
                    app:tint="@color/glass_ink" />

                <ImageButton
                    android:id="@+id/btnShare"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/main_cd_share"
                    android:src="@drawable/ic_share_24dp"
                    app:tint="@color/glass_ink" />
            </LinearLayout>
        </FrameLayout>

        <!-- The orb is the very last element: the thumb lands on the record target at the bottom
             edge, never reaching past a menu bar. -->
        <FrameLayout
            android:layout_width="184dp"
            android:layout_height="184dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp">

            <com.whispertflite.ui.LivingSignalView
                android:id="@+id/orb"
                android:layout_width="184dp"
                android:layout_height="184dp" />

            <ImageButton
                android:id="@+id/btnRecord"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:contentDescription="@string/main_cd_record" />
        </FrameLayout>
    </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
