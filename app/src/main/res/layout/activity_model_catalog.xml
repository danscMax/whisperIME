<?xml version="1.0" encoding="utf-8"?>
<!-- Model catalog: cards scroll under a frosted top bar (toolbar + filters) and a frosted footer. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/living_signal_backdrop"
    android:fitsSystemWindows="true">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp" />
    <!-- paddingTop/Bottom set in code to the frosted bars' heights -->

    <com.whispertflite.ui.FrostedBlurView
        android:id="@+id/blurBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@android:color/transparent"
                app:navigationIcon="@drawable/ic_arrow_back_24dp"
                app:navigationIconTint="@color/aurora_ink"
                app:title="@string/catalog_title"
                app:titleTextAppearance="@style/TextAppearance.Aurora.Toolbar"
                app:titleTextColor="@color/aurora_ink" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/filterGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="4dp"
                app:selectionRequired="true"
                app:singleLine="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/filterAll"
                    style="@style/Widget.Aurora.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/catalog_filter_all" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/filterTflite"
                    style="@style/Widget.Aurora.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/catalog_filter_tflite" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/filterWhisperCpp"
                    style="@style/Widget.Aurora.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/catalog_filter_whispercpp" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>
    </com.whispertflite.ui.FrostedBlurView>

    <com.whispertflite.ui.FrostedBlurView
        android:id="@+id/footerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/storageUsed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/wifiOnlySwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/catalog_wifi_only" />
        </LinearLayout>
    </com.whispertflite.ui.FrostedBlurView>
</FrameLayout>
