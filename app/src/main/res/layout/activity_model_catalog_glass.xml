<?xml version="1.0" encoding="utf-8"?>
<!-- Liquid-glass variant of the model catalog (light frosted, iridescent cards). Ids match the activity. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/liquid_glass_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:navigationIcon="@drawable/ic_arrow_back_24dp"
        app:navigationIconTint="#161B2C"
        app:title="@string/catalog_title"
        app:titleTextColor="#161B2C" />

    <!-- glass search pill (style fidelity to the reference) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/liquid_glass_card"
        android:drawableStart="@drawable/ic_search_24dp"
        android:drawablePadding="10dp"
        android:drawableTint="#7A8096"
        android:paddingHorizontal="16dp"
        android:paddingVertical="13dp"
        android:text="@string/catalog_title"
        android:textColor="#7A8096"
        android:textSize="15sp"
        android:visibility="gone" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/filterGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="14dp"
        android:layout_marginBottom="6dp"
        app:selectionRequired="true"
        app:singleLine="true"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/filterAll"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/catalog_filter_all" />

        <com.google.android.material.chip.Chip
            android:id="@+id/filterTflite"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/catalog_filter_tflite" />

        <com.google.android.material.chip.Chip
            android:id="@+id/filterWhisperCpp"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/catalog_filter_whispercpp" />
    </com.google.android.material.chip.ChipGroup>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="10dp"
        android:paddingBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="@drawable/liquid_glass_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingVertical="12dp">

        <TextView
            android:id="@+id/storageUsed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#3A3F4E"
            android:textSize="14sp" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/wifiOnlySwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/catalog_wifi_only"
            android:textColor="#3A3F4E" />
    </LinearLayout>
</LinearLayout>
