<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/living_signal_backdrop"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/living_glass_pill"
            android:contentDescription="@android:string/cancel"
            android:src="@drawable/ic_arrow_back_24dp"
            app:tint="@color/aurora_ink" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:fontFamily="@font/space_grotesk"
            android:text="@string/voice_input"
            android:textColor="@color/aurora_ink"
            android:textFontWeight="700"
            android:textSize="21sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/living_glass_panel"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_mono_regular"
            android:letterSpacing="0.08"
            android:text="@string/settings_recognition"
            android:textAllCaps="true"
            android:textColor="@color/living_cyan"
            android:textSize="10sp" />

        <!-- The pills carry their own label: a floating hint would notch a gap through the
             glass stroke, and these two values are not self-describing on a settings form. -->
        <TextView
            style="@style/TextAppearance.LivingSignal.FieldLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/select_model" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRecognitionModel"
            style="@style/Widget.LivingSignal.Dropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/spnrTfliteFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk"
                android:inputType="none"
                android:popupBackground="@drawable/menu_sheet"
                android:textColor="@color/aurora_ink" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            style="@style/TextAppearance.LivingSignal.FieldLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/language" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_language"
            style="@style/Widget.LivingSignal.Dropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/spnrLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk"
                android:inputType="none"
                android:popupBackground="@drawable/menu_sheet"
                android:textColor="@color/aurora_ink" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/mode_simple_chinese"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:text="@string/settings_simple_chinese"
            android:textColor="@color/aurora_ink" />
    </LinearLayout>
</LinearLayout>
