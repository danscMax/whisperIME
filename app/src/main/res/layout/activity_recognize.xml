<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:background="@drawable/dialog_sheet_background"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="18dp">

    <View
        android:layout_width="38dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="9dp"
        android:layout_marginBottom="5dp"
        android:alpha="0.55"
        android:background="@drawable/dialog_drag_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk"
                android:text="@string/dialog_dictate"
                android:textColor="@color/glass_ink"
                android:textFontWeight="700"
                android:textSize="19sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_mono_regular"
                android:text="@string/main_local_badge"
                android:textColor="@color/glass_ink_body"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Recognition mode: push-to-talk by default, tap to switch to hands-free auto (VAD). -->
        <TextView
            android:id="@+id/dialog_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/living_glass_pill"
            android:contentDescription="@string/dialog_mode_cd"
            android:fontFamily="@font/space_mono_regular"
            android:letterSpacing="0.04"
            android:paddingHorizontal="16dp"
            android:paddingVertical="9dp"
            android:text="@string/dialog_mode_hold"
            android:textAllCaps="true"
            android:textColor="@color/glass_ink"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Status and the live transcription read at the top; the orb is the hero at the very bottom,
         under the thumb — same reach-first logic as the main screen. -->
    <LinearLayout
        android:id="@+id/dialog_main_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/dialog_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/living_glass_pill"
            android:ellipsize="end"
            android:fontFamily="@font/space_mono_regular"
            android:letterSpacing="0.03"
            android:maxLines="1"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp"
            android:textColor="@color/glass_ink_dim"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/dialog_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/space_grotesk"
            android:gravity="center"
            android:text="@string/dialog_tap_to_talk"
            android:textColor="@color/glass_ink"
            android:textFontWeight="700"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/dialog_partial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:fontFamily="@font/space_grotesk"
            android:gravity="center"
            android:lineSpacingMultiplier="1.15"
            android:maxLines="3"
            android:minHeight="52dp"
            android:textColor="@color/glass_ink_dim"
            android:textSize="16sp" />

        <!-- Orb at the bottom centre, flanked by keyboard (switch to typing) and close — the
             thumb reaches the record target, and the buttons fill the sides instead of empty space. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnKeyboard"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/glass_circle_btn"
                android:contentDescription="@string/switch_to_keyboard"
                android:padding="14dp"
                android:src="@drawable/ic_keyboard_36dp"
                app:tint="@color/glass_ink" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <FrameLayout
                android:layout_width="176dp"
                android:layout_height="176dp">

                <com.whispertflite.ui.LivingSignalView
                    android:id="@+id/orb"
                    android:layout_width="176dp"
                    android:layout_height="176dp" />

                <ImageButton
                    android:id="@+id/btnRecord"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/record_button" />
            </FrameLayout>

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnCancel"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/glass_circle_btn"
                android:contentDescription="@android:string/cancel"
                android:padding="15dp"
                android:src="@drawable/ic_close_24dp"
                app:tint="@color/glass_ink" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/dialog_no_model_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:background="@drawable/living_glass_panel"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="22dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_grotesk"
            android:text="@string/dialog_no_model_title"
            android:textColor="@color/glass_ink"
            android:textFontWeight="600"
            android:textSize="17sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:gravity="center"
            android:text="@string/dialog_no_model_desc"
            android:textColor="@color/glass_ink_dim"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialog_open_catalog"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/dialog_open_catalog" />
    </LinearLayout>
</LinearLayout>
