<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_sheet_background"
    android:layout_gravity="bottom"
    android:paddingBottom="18dp">

    <!-- Drag handle -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/dialog_drag_handle"
        android:alpha="0.4" />

    <!-- Top action row: cancel (left), auto-mode (right) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:id="@+id/btnCancel"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_cancel_36dp"
            android:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="@string/exit_button" />

        <ImageButton
            android:id="@+id/btnModeAuto"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_auto_off_36dp"
            android:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="@string/auto_button" />

    </RelativeLayout>

    <ProgressBar
        android:id="@+id/processing_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:visibility="invisible"
        android:indeterminate="false"
        android:progressTint="?attr/colorPrimary"
        android:indeterminateTint="?attr/colorPrimary"
        style="?android:attr/progressBarStyleHorizontal" />

    <!-- Normal (listening / processing) state -->
    <LinearLayout
        android:id="@+id/dialog_main_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp">

        <ImageButton
            android:id="@+id/btnRecord"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/dialog_mic_circle"
            android:src="@drawable/ic_mic_48dp"
            android:tint="?attr/colorOnPrimaryContainer"
            android:contentDescription="@string/record_button" />

        <TextView
            android:id="@+id/dialog_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface"
            android:text="@string/dialog_hold_to_speak" />

        <TextView
            android:id="@+id/dialog_partial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:minHeight="24dp"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/dialog_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="@drawable/chip_background"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorOnPrimaryContainer" />

    </LinearLayout>

    <!-- Edge state: no model downloaded -->
    <LinearLayout
        android:id="@+id/dialog_no_model_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:visibility="gone"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="26sp"
            android:text="📦" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface"
            android:text="@string/dialog_no_model_title" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:text="@string/dialog_no_model_desc" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialog_open_catalog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/dialog_open_catalog" />

    </LinearLayout>

</LinearLayout>
