<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:background="@drawable/dialog_sheet_background"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="18dp">

    <View
        android:layout_width="38dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="9dp"
        android:layout_marginBottom="5dp"
        android:alpha="0.55"
        android:background="@drawable/dialog_drag_handle" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="48dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk"
                android:text="@string/dialog_dictate"
                android:textColor="@color/glass_ink"
                android:textFontWeight="700"
                android:textSize="19sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_mono_regular"
                android:text="@string/main_local_badge"
                android:textColor="@color/glass_ink_dim"
                android:textSize="9sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnCancel"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/living_glass_circle"
            android:contentDescription="@string/exit_button"
            android:padding="12dp"
            android:src="@drawable/ic_cancel_36dp"
            app:tint="@color/glass_ink" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/dialog_main_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:background="@drawable/living_glass_panel"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="22dp"
        android:paddingBottom="20dp">

        <FrameLayout
            android:layout_width="136dp"
            android:layout_height="136dp">

            <com.whispertflite.ui.LivingSignalView
                android:id="@+id/orb"
                android:layout_width="136dp"
                android:layout_height="136dp" />

            <ImageButton
                android:id="@+id/btnRecord"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:contentDescription="@string/record_button" />
        </FrameLayout>

        <TextView
            android:id="@+id/dialog_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/space_grotesk"
            android:gravity="center"
            android:text="@string/dialog_tap_to_talk"
            android:textColor="@color/glass_ink"
            android:textFontWeight="600"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/dialog_partial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="3"
            android:minHeight="40dp"
            android:textColor="@color/glass_ink_dim"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/dialog_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/living_glass_pill"
            android:ellipsize="end"
            android:fontFamily="@font/space_mono_regular"
            android:letterSpacing="0.03"
            android:maxLines="1"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:textColor="@color/glass_ink_dim"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/dialog_no_model_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:background="@drawable/living_glass_panel"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="22dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_grotesk"
            android:text="@string/dialog_no_model_title"
            android:textColor="@color/glass_ink"
            android:textFontWeight="600"
            android:textSize="17sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:gravity="center"
            android:text="@string/dialog_no_model_desc"
            android:textColor="@color/glass_ink_dim"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialog_open_catalog"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/dialog_open_catalog" />
    </LinearLayout>
</LinearLayout>
