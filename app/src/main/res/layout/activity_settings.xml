<?xml version="1.0" encoding="utf-8"?>
<!-- Aurora: dark radial bg, frosted panels, Space Grotesk chrome. All view ids preserved for
     SettingsActivity. Newbie-first order: Model/language -> How to use -> Appearance -> Advanced
     (collapsed). The theme toggle + palette swatches stay live. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@drawable/liquid_glass_bg">

    <!-- top bar: circle back + Space Grotesk title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/living_glass_pill"
            android:src="@drawable/ic_arrow_back_24dp"
            app:tint="@color/glass_ink"
            android:contentDescription="@android:string/cancel" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/space_grotesk"
            android:text="@string/settings_title"
            android:textColor="@color/glass_ink"
            android:textFontWeight="700"
            android:textSize="22sp"
            android:letterSpacing="-0.02" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <!-- Cap + centre the settings column so it doesn't stretch across a tablet. -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/settings_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp"
            app:layout_constraintWidth_max="@dimen/content_max_width"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- 1. Model & language — the first decision, surfaced to the top -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/living_glass_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_grotesk"
                    android:text="@string/settings_model_language"
                    android:textColor="?attr/colorPrimary"
                    android:textFontWeight="600"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_model_language_sub"
                    android:textColor="@color/glass_ink_dim"
                    android:textSize="13sp" />

                <!-- Inline picker of models already on device — switch the active one without
                     leaving Settings. Rows are built in SettingsActivity#buildModelList(). -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/settings_model_pick"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <LinearLayout
                    android:id="@+id/model_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/row_models"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:text="@string/settings_models"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <!-- 2. How to use — enable the keyboard, then the voice-input surface -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/living_glass_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_grotesk"
                    android:text="@string/settings_howto"
                    android:textColor="?attr/colorPrimary"
                    android:textFontWeight="600"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_howto_sub"
                    android:textColor="@color/glass_ink_dim"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/record_mode_label"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/record_mode_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mode_hold"
                        style="@style/Widget.Glass.SegButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/dialog_mode_hold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mode_tap"
                        style="@style/Widget.Glass.SegButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/dialog_mode_tap" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mode_auto"
                        style="@style/Widget.Glass.SegButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/dialog_mode_autostart" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <TextView
                    android:id="@+id/row_enable_keyboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:text="@string/settings_enable_keyboard"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />

            </LinearLayout>

            <!-- 3. Appearance -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/living_glass_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_grotesk"
                    android:text="@string/settings_appearance"
                    android:textColor="?attr/colorPrimary"
                    android:textFontWeight="600"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/settings_palette"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <LinearLayout
                    android:id="@+id/palette_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/settings_theme"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/theme_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/theme_system"
                        style="@style/Widget.Glass.SegButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_system" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/theme_light"
                        style="@style/Widget.Glass.SegButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_light" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/theme_dark"
                        style="@style/Widget.Glass.SegButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_dark" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/settings_orb"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/orb_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/orb_cloud"
                        style="@style/Widget.Glass.SegButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_orb_cloud" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/orb_plasma"
                        style="@style/Widget.Glass.SegButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_orb_plasma" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

            <!-- 4. Advanced — collapsed by default; power settings live here -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/living_glass_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:id="@+id/advanced_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/space_grotesk"
                        android:text="@string/settings_advanced"
                        android:textColor="?attr/colorPrimary"
                        android:textFontWeight="600"
                        android:textSize="16sp" />

                    <ImageView
                        android:id="@+id/advanced_chevron"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_expand_more_24dp"
                        android:contentDescription="@string/settings_advanced"
                        app:tint="@color/glass_ink_dim" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/advanced_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_haptic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:minHeight="48dp"
                        android:gravity="center_vertical"
                        android:text="@string/settings_haptic"
                        android:textColor="@color/glass_ink" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_tts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:gravity="center_vertical"
                        android:text="@string/settings_tts"
                        android:textColor="@color/glass_ink" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_simple_chinese"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:gravity="center_vertical"
                        android:text="@string/settings_simple_chinese"
                        android:textColor="@color/glass_ink" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/space_grotesk"
                        android:text="@string/settings_vocabulary"
                        android:textColor="@color/glass_ink"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_vocabulary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/living_glass_panel"
                        android:fontFamily="@font/space_grotesk"
                        android:hint="@string/settings_vocabulary_hint"
                        android:importantForAutofill="no"
                        android:inputType="textMultiLine|textCapSentences"
                        android:maxLines="3"
                        android:minHeight="48dp"
                        android:padding="12dp"
                        android:textColor="@color/glass_ink"
                        android:textColorHint="@color/glass_ink_dim"
                        android:textSize="14sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:minHeight="48dp"
                        android:gravity="center_vertical"
                        android:text="@string/settings_history_save"
                        android:textColor="@color/glass_ink" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_history_ime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:gravity="center_vertical"
                        android:text="@string/settings_history_from_ime"
                        android:textColor="@color/glass_ink" />

                    <TextView
                        android:id="@+id/row_history_open"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:minHeight="48dp"
                        android:text="@string/settings_history_open"
                        android:textColor="@color/glass_ink"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <TextView
                        android:id="@+id/row_github"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:minHeight="48dp"
                        android:text="@string/settings_github"
                        android:textColor="@color/glass_ink"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</LinearLayout>
