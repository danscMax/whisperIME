<?xml version="1.0" encoding="utf-8"?>
<!-- Aurora: dark radial bg, frosted panels, Space Grotesk chrome. All view ids preserved for
     SettingsActivity. Section cards are plain panels; the theme toggle + palette swatches stay live. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@drawable/liquid_glass_bg">

    <!-- top bar: circle back + Space Grotesk title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/living_glass_pill"
            android:src="@drawable/ic_arrow_back_24dp"
            app:tint="@color/glass_ink"
            android:contentDescription="@android:string/cancel" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/space_grotesk"
            android:text="@string/settings_title"
            android:textColor="@color/glass_ink"
            android:textFontWeight="700"
            android:textSize="22sp"
            android:letterSpacing="-0.02" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <!-- Cap + centre the settings column so it doesn't stretch across a tablet. -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp"
            app:layout_constraintWidth_max="@dimen/content_max_width"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Appearance -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/living_glass_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_grotesk"
                    android:text="@string/settings_appearance"
                    android:textColor="?attr/colorPrimary"
                    android:textFontWeight="600"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/settings_palette"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <LinearLayout
                    android:id="@+id/palette_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/settings_theme"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/theme_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/theme_system"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_system" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/theme_light"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_light" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/theme_dark"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_dark" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/settings_orb"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/orb_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/orb_cloud"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_orb_cloud" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/orb_plasma"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_orb_plasma" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

            <!-- Recognition -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/living_glass_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/space_grotesk"
                    android:text="@string/settings_recognition"
                    android:textColor="?attr/colorPrimary"
                    android:textFontWeight="600"
                    android:textSize="16sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_haptic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:gravity="center_vertical"
                    android:text="@string/settings_haptic"
                    android:textColor="@color/glass_ink" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_tts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:gravity="center_vertical"
                    android:text="@string/settings_tts"
                    android:textColor="@color/glass_ink" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_simple_chinese"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:gravity="center_vertical"
                    android:text="@string/settings_simple_chinese"
                    android:textColor="@color/glass_ink" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/space_grotesk"
                    android:text="@string/settings_vocabulary"
                    android:textColor="@color/glass_ink"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edit_vocabulary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/living_glass_panel"
                    android:fontFamily="@font/space_grotesk"
                    android:hint="@string/settings_vocabulary_hint"
                    android:importantForAutofill="no"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="3"
                    android:minHeight="48dp"
                    android:padding="12dp"
                    android:textColor="@color/glass_ink"
                    android:textColorHint="@color/glass_ink_dim"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- History -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/living_glass_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/space_grotesk"
                    android:text="@string/settings_history"
                    android:textColor="?attr/colorPrimary"
                    android:textFontWeight="600"
                    android:textSize="16sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:gravity="center_vertical"
                    android:text="@string/settings_history_save"
                    android:textColor="@color/glass_ink" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_history_ime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:gravity="center_vertical"
                    android:text="@string/settings_history_from_ime"
                    android:textColor="@color/glass_ink" />

                <TextView
                    android:id="@+id/row_history_open"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:text="@string/settings_history_open"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <!-- System -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/living_glass_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/space_grotesk"
                    android:text="@string/settings_system"
                    android:textColor="?attr/colorPrimary"
                    android:textFontWeight="600"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/row_models"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:text="@string/settings_models"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />

                <TextView
                    android:id="@+id/row_enable_keyboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:text="@string/settings_enable_keyboard"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />

                <TextView
                    android:id="@+id/row_voice_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:text="@string/settings_voice_input"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />

                <TextView
                    android:id="@+id/row_github"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:text="@string/settings_github"
                    android:textColor="@color/glass_ink"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>
        </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</LinearLayout>
