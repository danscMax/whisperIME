<?xml version="1.0" encoding="utf-8"?>
<!-- The one thing first-run users miss: Sweet Whisper is invoked FROM another keyboard, it doesn't
     replace it. Words alone didn't land (user test 2026-07-20), so the gesture is shown as three
     numbered steps with icons and repeated on every screen where it matters (setup, test, done). -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/OnbCard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            style="@style/OnbCardTitle"
            android:text="@string/onb_howto_title" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_keyboard_36dp"
                app:tint="?attr/colorPrimary" />

            <TextView
                style="@style/OnbCardBody"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/onb_howto_1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_mic_48dp"
                app:tint="?attr/colorPrimary" />

            <TextView
                style="@style/OnbCardBody"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/onb_howto_2" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_check_20dp"
                app:tint="?attr/colorPrimary" />

            <TextView
                style="@style/OnbCardBody"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/onb_howto_3" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
