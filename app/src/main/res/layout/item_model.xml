<?xml version="1.0" encoding="utf-8"?>
<!-- Compact model row: name + inline action on the first line, a dense stats line below. The engine
     is carried by the section header (item_model_header), so no per-row engine badge or icon tile. -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/glass_card"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/glass_card_brd"
    app:strokeWidth="1dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/cardSheen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/card_sheen_glass" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="15dp"
            android:paddingEnd="8dp"
            android:paddingVertical="11dp">

            <!-- Line 1: name + status/action, all on one row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="40dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/space_grotesk"
                    android:maxLines="1"
                    android:textColor="@color/glass_ink"
                    android:textFontWeight="700"
                    android:textSize="16sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/statusChip"
                    style="@style/Widget.Glass.Chip.Status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:clickable="false"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/useButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/catalog_use"
                    android:padding="9dp"
                    android:src="@drawable/ic_check_20dp"
                    android:visibility="gone"
                    app:tint="@color/glass_warm" />

                <ImageButton
                    android:id="@+id/downloadButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/catalog_download"
                    android:padding="8dp"
                    android:src="@drawable/ic_download_48dp"
                    android:visibility="gone"
                    app:tint="@color/glass_ink_body" />

                <ImageButton
                    android:id="@+id/deleteButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/catalog_delete"
                    android:padding="9dp"
                    android:src="@drawable/ic_delete_24dp"
                    android:visibility="gone"
                    app:tint="@color/glass_danger" />
            </LinearLayout>

            <!-- Line 2: dense stats (languages · size · speed · quality [· slow-on-phone]) -->
            <TextView
                android:id="@+id/meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="7dp"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:fontFamily="@font/space_mono_regular"
                android:maxLines="1"
                android:textColor="@color/glass_ink_dim"
                android:textSize="12sp" />

            <!-- DOWNLOADING: progress replaces the action -->
            <LinearLayout
                android:id="@+id/progressGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:indicatorColor="@color/glass_warm"
                        app:trackColor="@color/glass_outline"
                        app:trackCornerRadius="4dp" />

                    <ImageButton
                        android:id="@+id/cancelButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/catalog_cancel"
                        android:padding="6dp"
                        android:src="@drawable/ic_cancel_36dp"
                        app:tint="@color/glass_ink_body" />
                </LinearLayout>

                <TextView
                    android:id="@+id/progressText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:fontFamily="@font/space_mono_regular"
                    android:textColor="@color/glass_ink_dim"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
