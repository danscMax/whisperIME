<?xml version="1.0" encoding="utf-8"?>
<!-- IME strip, three states driven by WhisperInputMethodService:
     IDLE (mic + hint + model·lang chip + keys), RECORDING (stop + waveform + timer),
     PROCESSING (spinner in the mic slot; chunk text streams into the target field). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:fitsSystemWindows="true"
    android:background="@color/aurora_bg2"
    android:minHeight="64dp"
    android:paddingHorizontal="10dp"
    android:paddingVertical="8dp">

    <!-- Mic / stop / processing slot -->
    <FrameLayout
        android:layout_width="52dp"
        android:layout_height="52dp">

        <View
            android:id="@+id/record_ring"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:background="@drawable/ime_mic_ring"
            android:visibility="gone" />

        <!-- The living orb is the mic affordance; a transparent button over it handles touch. -->
        <com.whispertflite.ui.AuroraOrbView
            android:id="@+id/orb"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center" />

        <ImageButton
            android:id="@+id/btnRecord"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:background="@android:color/transparent"
            android:contentDescription="@string/record_button" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/processing_spinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorSize="36dp"
            app:trackThickness="3dp" />

    </FrameLayout>

    <!-- Center: idle hint+chip, or live waveform, or error text -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="6dp">

        <LinearLayout
            android:id="@+id/idle_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ime_hint"
                android:textColor="@color/aurora_ink_dim"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_model_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/aurora_ink"
                android:textSize="10sp"
                tools:ignore="SmallSp" />

        </LinearLayout>

        <com.whispertflite.ui.WaveformView
            android:id="@+id/waveform"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_gravity="center_vertical"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:textColor="?attr/colorError"
            android:textSize="12sp"
            android:visibility="gone" />

    </FrameLayout>

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="6dp"
        android:text="0:00"
        android:textColor="?attr/colorError"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Right-side keys -->
    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnTranslate"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:tint="@color/aurora_ink"
            android:src="@drawable/ic_english_off_36dp"
            android:contentDescription="@string/translate" />

        <ImageButton
            android:id="@+id/btnModeAuto"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:tint="@color/aurora_ink"
            android:src="@drawable/ic_auto_off_36dp"
            android:contentDescription="@string/auto_button" />

        <ImageButton
            android:id="@+id/btnDel"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:tint="@color/aurora_ink"
            android:src="@drawable/ic_keyboard_del_48dp"
            android:contentDescription="@string/delete_button" />

        <ImageButton
            android:id="@+id/btnEnter"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:tint="@color/aurora_ink"
            android:src="@drawable/ic_keyboard_return_48dp"
            android:contentDescription="@string/return_button" />

        <ImageButton
            android:id="@+id/btnKeyboard"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:tint="@color/aurora_ink"
            android:src="@drawable/ic_keyboard_36dp"
            android:contentDescription="@string/exit_button" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="7dp"
            android:scaleType="fitCenter"
            android:tint="@color/aurora_ink"
            android:src="@drawable/ic_settings_24dp"
            android:contentDescription="@string/ime_cd_settings" />

    </LinearLayout>

</LinearLayout>
