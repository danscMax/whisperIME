<?xml version="1.0" encoding="utf-8"?>
<!-- IME voice dock: centred orb hero, status above, glass circle actions flanking. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/ime_living_background"
    android:fitsSystemWindows="true"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="14dp">

    <!-- STATUS (centred, above the orb) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/idle_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/space_grotesk"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/ime_hint"
                android:textColor="@color/aurora_ink"
                android:textFontWeight="600"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_model_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:fontFamily="@font/space_mono_regular"
                android:gravity="center"
                android:letterSpacing="0.03"
                android:maxLines="1"
                android:textColor="@color/aurora_ink_dim"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:fontFamily="@font/space_mono_regular"
            android:text="0:00"
            android:textColor="@color/living_magenta"
            android:textSize="11sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="?attr/colorError"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- MAIN ROW: del · keyboard · [ ORB ] · enter · more -->
    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnDel"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/living_glass_circle"
            android:contentDescription="@string/delete_button"
            android:padding="13dp"
            android:src="@drawable/ic_ime_backspace_24dp"
            app:tint="@color/aurora_ink" />

        <ImageButton
            android:id="@+id/btnKeyboard"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/living_glass_circle"
            android:contentDescription="@string/exit_button"
            android:padding="13dp"
            android:src="@drawable/ic_keyboard_36dp"
            app:tint="@color/aurora_ink" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <FrameLayout
            android:layout_width="78dp"
            android:layout_height="78dp">

            <com.whispertflite.ui.LivingSignalView
                android:id="@+id/orb"
                android:layout_width="78dp"
                android:layout_height="78dp" />

            <ImageButton
                android:id="@+id/btnRecord"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:contentDescription="@string/record_button" />
        </FrameLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnEnter"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/living_glass_circle"
            android:contentDescription="@string/return_button"
            android:padding="13dp"
            android:src="@drawable/ic_ime_return_24dp"
            app:tint="@color/aurora_ink" />

        <ImageButton
            android:id="@+id/btnMore"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/living_glass_circle"
            android:contentDescription="@string/main_cd_menu"
            android:padding="13dp"
            android:src="@drawable/ic_more_vert_24dp"
            app:tint="@color/aurora_ink" />
    </LinearLayout>
</LinearLayout>
