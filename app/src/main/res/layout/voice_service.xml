<?xml version="1.0" encoding="utf-8"?>
<!-- IME voice dock (orb-forward): the orb is the hero and dominates; backspace + enter hug it. The
     keyboard-switch and overflow are small icons tucked into the top-right corner. The status/model
     line sits directly UNDER the orb (compact) so nothing floats far above it. Orb + keys scale up on
     tablets via @dimen (values-sw600dp). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/ime_living_background"
    android:fitsSystemWindows="true"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingTop="4dp"
    android:paddingBottom="8dp">

    <!-- ORB ZONE: centred cluster — backspace · [ BIG ORB ] · enter. The keyboard-switch + overflow
         float in the top-right corner (they sit above the orb's centre line, so they never collide
         with the enter key). -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/layout_buttons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnDel"
                android:layout_width="@dimen/ime_key_size"
                android:layout_height="@dimen/ime_key_size"
                android:background="@drawable/living_glass_circle"
                android:contentDescription="@string/delete_button"
                android:padding="14dp"
                android:src="@drawable/ic_ime_backspace_24dp"
                app:tint="@color/glass_ink" />

            <Space
                android:layout_width="16dp"
                android:layout_height="1dp" />

            <FrameLayout
                android:layout_width="@dimen/ime_orb_size"
                android:layout_height="@dimen/ime_orb_size">

                <com.whispertflite.ui.LivingSignalView
                    android:id="@+id/orb"
                    android:layout_width="@dimen/ime_orb_size"
                    android:layout_height="@dimen/ime_orb_size" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnRecord"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/record_button" />

                <!-- Recording timer overlays the orb's lower edge, so showing/hiding it never
                     reflows the caption stack (the dock used to "jump" when it appeared). -->
                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="@font/space_mono_regular"
                    android:text="0:00"
                    android:textColor="@color/glass_ink"
                    android:textSize="11sp"
                    android:visibility="gone" />
            </FrameLayout>

            <Space
                android:layout_width="16dp"
                android:layout_height="1dp" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnEnter"
                android:layout_width="@dimen/ime_key_size"
                android:layout_height="@dimen/ime_key_size"
                android:background="@drawable/living_glass_circle"
                android:contentDescription="@string/return_button"
                android:padding="14dp"
                android:src="@drawable/ic_ime_return_24dp"
                app:tint="@color/glass_ink" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnKeyboard"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/living_glass_circle"
                android:contentDescription="@string/exit_button"
                android:padding="9dp"
                android:src="@drawable/ic_keyboard_36dp"
                app:tint="@color/glass_ink_dim" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnMore"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/living_glass_circle"
                android:contentDescription="@string/main_cd_menu"
                android:padding="9dp"
                android:src="@drawable/ic_more_vert_24dp"
                app:tint="@color/glass_ink_dim" />
        </LinearLayout>
    </FrameLayout>

    <!-- Status / model line — directly under the orb, compact -->
    <LinearLayout
        android:id="@+id/idle_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ime_caption_pull"
        android:layout_marginBottom="2dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/space_grotesk"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/ime_hint"
            android:textColor="@color/glass_ink"
            android:textFontWeight="600"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_model_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/space_mono_regular"
            android:gravity="center"
            android:letterSpacing="0.02"
            android:maxLines="1"
            android:textColor="@color/glass_ink_dim"
            android:textSize="10sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/glass_ink"
        android:textSize="12sp"
        android:visibility="gone" />
</LinearLayout>
