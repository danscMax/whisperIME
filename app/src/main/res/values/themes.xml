<resources>
    <!-- Base application theme. -->
    <style name="Theme.Whisper.NoActionBar" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">@color/windowBackground</item>
    </style>

    <!-- Base application theme. -->
    <style name="Theme.Whisper.ActionBar" parent="Theme.Material3.DayNight">
        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">@color/windowBackground</item>
    </style>

    <style name="Theme.WhisperFloating" parent="Theme.Whisper.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <!-- Palette overlays applied at runtime by ThemeUtils.applyPalette. -->
    <style name="ThemeOverlay.Whisper.Teal" parent="">
        <item name="colorPrimary">@color/palette_teal_primary</item>
        <item name="colorOnPrimary">@color/palette_teal_onPrimary</item>
        <item name="colorPrimaryContainer">@color/palette_teal_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/palette_teal_onPrimaryContainer</item>
        <item name="colorSecondaryContainer">@color/palette_teal_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/palette_teal_onSecondaryContainer</item>
        <item name="android:colorBackground">@color/palette_teal_surface</item>
        <item name="colorSurface">@color/palette_teal_surface</item>
        <item name="colorOnSurface">@color/palette_teal_onSurface</item>
        <item name="colorSurfaceVariant">@color/palette_teal_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/palette_teal_onSurfaceVariant</item>
        <item name="colorOutline">@color/palette_teal_outline</item>
    </style>

