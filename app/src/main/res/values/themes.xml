<resources>
    <!-- Base application theme. -->
    <style name="Theme.Whisper.NoActionBar" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">@color/windowBackground</item>
        <item name="android:windowAnimationStyle">@style/Animation.Whisper.Activity</item>
    </style>

    <!-- Base application theme. -->
    <style name="Theme.Whisper.ActionBar" parent="Theme.Material3.DayNight">
        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">@color/windowBackground</item>
        <item name="android:windowAnimationStyle">@style/Animation.Whisper.Activity</item>
    </style>

    <!-- Simple, coherent fade for every activity open/close (Main <-> Settings/History/Catalog). -->
    <style name="Animation.Whisper.Activity" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityOpenExitAnimation">@android:anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@android:anim/fade_out</item>
    </style>

    <style name="Theme.WhisperFloating" parent="Theme.Whisper.NoActionBar">
        <!-- Keep the platform dialog animation for the floating recognizer. -->
        <item name="android:windowAnimationStyle">@android:style/Animation.Activity</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <!-- Force light-on-dark text inside the Aurora pills (spinners inherit android:textColorPrimary,
         which is dark under the palette's light surface and would be invisible on the dark screen). -->
    <style name="ThemeOverlay.Aurora.OnDark" parent="">
        <item name="android:textColorPrimary">@color/aurora_ink</item>
        <item name="android:textColorSecondary">@color/aurora_ink_dim</item>
        <item name="android:textColor">@color/aurora_ink</item>
        <item name="colorControlNormal">@color/aurora_ink</item>
    </style>

    <!-- Aurora toolbar title: Space Grotesk 700 in aurora ink (used by catalog + other dark chrome). -->
    <style name="TextAppearance.Aurora.Toolbar" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/space_grotesk</item>
        <item name="android:textFontWeight">700</item>
        <item name="android:textColor">@color/aurora_ink</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <!-- Aurora filter chip: translucent panel on dark, palette-accent fill when selected. -->
    <style name="Widget.Aurora.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="android:textColor">@color/aurora_chip_text</item>
        <item name="chipBackgroundColor">@color/aurora_chip_bg</item>
        <item name="chipStrokeColor">@color/aurora_chip_stroke</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipSurfaceColor">@android:color/transparent</item>
    </style>

    <!-- Aurora engine badge: solid accent pill, mono aurora-ink label (matches the main-screen badge). -->
    <style name="Widget.Aurora.Chip.Badge" parent="Widget.Material3.Chip.Suggestion">
        <item name="android:fontFamily">@font/space_mono_regular</item>
        <item name="android:textColor">@color/aurora_ink</item>
        <item name="android:textSize">10sp</item>
        <item name="chipBackgroundColor">?attr/colorPrimary</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipMinHeight">24dp</item>
        <item name="chipStartPadding">8dp</item>
        <item name="chipEndPadding">8dp</item>
        <item name="ensureMinTouchTargetSize">false</item>
        <item name="chipSurfaceColor">@android:color/transparent</item>
    </style>

    <!-- Aurora status chip (Active / engine soon): faint panel, aurora ink. -->
    <style name="Widget.Aurora.Chip.Status" parent="Widget.Material3.Chip.Suggestion">
        <item name="android:fontFamily">@font/space_mono_regular</item>
        <item name="android:textColor">@color/aurora_ink</item>
        <item name="android:textSize">10sp</item>
        <item name="chipBackgroundColor">@color/aurora_panel</item>
        <item name="chipStrokeColor">@color/aurora_panel_brd</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipMinHeight">24dp</item>
        <item name="chipStartPadding">8dp</item>
        <item name="chipEndPadding">8dp</item>
        <item name="ensureMinTouchTargetSize">false</item>
        <item name="chipSurfaceColor">@android:color/transparent</item>
    </style>

    <!-- Aurora toggle chip: a clean pill that fills with the accent when on. -->
    <style name="Widget.Aurora.Chip.Toggle" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/aurora_chip_bg</item>
        <item name="android:textColor">@color/aurora_chip_text</item>
        <item name="chipStrokeColor">@color/aurora_chip_stroke</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconEnabled">false</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipIconVisible">false</item>
        <item name="ensureMinTouchTargetSize">true</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Palette overlays applied at runtime by ThemeUtils.applyPalette. -->
    <style name="ThemeOverlay.Whisper.Teal" parent="">
        <item name="colorPrimary">@color/palette_teal_primary</item>
        <item name="colorOnPrimary">@color/palette_teal_onPrimary</item>
        <item name="colorPrimaryContainer">@color/palette_teal_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/palette_teal_onPrimaryContainer</item>
        <item name="colorSecondaryContainer">@color/palette_teal_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/palette_teal_onSecondaryContainer</item>
        <item name="android:colorBackground">@color/palette_teal_surface</item>
        <item name="colorSurface">@color/palette_teal_surface</item>
        <item name="colorOnSurface">@color/palette_teal_onSurface</item>
        <item name="colorSurfaceVariant">@color/palette_teal_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/palette_teal_onSurfaceVariant</item>
        <item name="colorOutline">@color/palette_teal_outline</item>
    </style>

    <style name="ThemeOverlay.Whisper.Terracotta" parent="">
        <item name="colorPrimary">@color/palette_terracotta_primary</item>
        <item name="colorOnPrimary">@color/palette_terracotta_onPrimary</item>
        <item name="colorPrimaryContainer">@color/palette_terracotta_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/palette_terracotta_onPrimaryContainer</item>
        <item name="colorSecondaryContainer">@color/palette_terracotta_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/palette_terracotta_onSecondaryContainer</item>
        <item name="android:colorBackground">@color/palette_terracotta_surface</item>
        <item name="colorSurface">@color/palette_terracotta_surface</item>
        <item name="colorOnSurface">@color/palette_terracotta_onSurface</item>
        <item name="colorSurfaceVariant">@color/palette_terracotta_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/palette_terracotta_onSurfaceVariant</item>
        <item name="colorOutline">@color/palette_terracotta_outline</item>
    </style>

    <style name="ThemeOverlay.Whisper.Indigo" parent="">
        <item name="colorPrimary">@color/palette_indigo_primary</item>
        <item name="colorOnPrimary">@color/palette_indigo_onPrimary</item>
        <item name="colorPrimaryContainer">@color/palette_indigo_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/palette_indigo_onPrimaryContainer</item>
        <item name="colorSecondaryContainer">@color/palette_indigo_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/palette_indigo_onSecondaryContainer</item>
        <item name="android:colorBackground">@color/palette_indigo_surface</item>
        <item name="colorSurface">@color/palette_indigo_surface</item>
        <item name="colorOnSurface">@color/palette_indigo_onSurface</item>
        <item name="colorSurfaceVariant">@color/palette_indigo_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/palette_indigo_onSurfaceVariant</item>
        <item name="colorOutline">@color/palette_indigo_outline</item>
    </style>

    <style name="ThemeOverlay.Whisper.Forest" parent="">
        <item name="colorPrimary">@color/palette_forest_primary</item>
        <item name="colorOnPrimary">@color/palette_forest_onPrimary</item>
        <item name="colorPrimaryContainer">@color/palette_forest_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/palette_forest_onPrimaryContainer</item>
        <item name="colorSecondaryContainer">@color/palette_forest_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/palette_forest_onSecondaryContainer</item>
        <item name="android:colorBackground">@color/palette_forest_surface</item>
        <item name="colorSurface">@color/palette_forest_surface</item>
        <item name="colorOnSurface">@color/palette_forest_onSurface</item>
        <item name="colorSurfaceVariant">@color/palette_forest_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/palette_forest_onSurfaceVariant</item>
        <item name="colorOutline">@color/palette_forest_outline</item>
    </style>

</resources>